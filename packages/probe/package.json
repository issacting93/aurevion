{
  "name": "probe-ui",
  "version": "0.1.0",
  "description": "DOM inspect overlay for React. Hover to measure, click to read specs.",
  "author": "Aurevion",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/aurevion/probe-ui"
  },
  "homepage": "https://github.com/aurevion/probe-ui#readme",
  "type": "module",
  "main": "./dist/probe.cjs.js",
  "module": "./dist/probe.es.js",
  "exports": {
    ".": {
      "import": "./dist/probe.es.js",
      "require": "./dist/probe.cjs.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.5.2",
    "vite": "^6.3.5"
  },
  "keywords": [
    "react",
    "inspect",
    "devtools",
    "overlay",
    "dom",
    "measure",
    "css",
    "specs",
    "design-system"
  ]
}
